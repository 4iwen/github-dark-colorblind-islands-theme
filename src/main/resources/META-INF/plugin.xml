<idea-plugin>
    <id>com.github.sebastian-abj.gruvbox-islands-theme</id>
    <name>Gruvbox - Islands</name>
    <vendor>Sebastian Jones</vendor>

    <description><![CDATA[
    Fork from https://plugins.jetbrains.com/plugin/20558-gruvbox--theme.

    This theme alters existing Gruv themes to use the new “Islands” parent theme.
    ]]></description>

    <!-- please see http://www.jetbrains.org/intellij/sdk/docs/basics/getting_started/plugin_compatibility.html
         on how to target different products -->
    <!-- uncomment to enable plugin in all products -->
    <depends>com.intellij.modules.lang</depends>

    <extensions defaultExtensionNs="com.intellij">
        <!-- Add your extensions here -->
        <themeProvider id="054aba82-2d51-4402-b570-199e3dac3fa0" path="/gruvbox_dark_medium_islands.theme.json"/>
        <themeProvider id="13612cfd-470b-4474-8536-f34e09721e5a" path="/gruvbox_dark_soft_islands.theme.json"/>
        <themeProvider id="73c73716-2665-405d-bd87-c0f3ce84ca54" path="/gruvbox_dark_hard_islands.theme.json"/>
        <themeProvider id="4f810e8b-0623-4210-b7b3-868f26dc99cd" path="/gruvbox_light_medium_islands.theme.json"/>
        <themeProvider id="96405325-e9be-4ab6-a588-cc99c7350c03" path="/gruvbox_light_soft_islands.theme.json"/>
        <themeProvider id="03dd9438-30cb-42ad-bd5f-de2b9dd4cccf" path="/gruvbox_light_hard_islands.theme.json"/>
    </extensions>

    <actions>
        <!-- Add your actions here -->
    </actions>
</idea-plugin>